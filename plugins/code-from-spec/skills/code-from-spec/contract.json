{
  "version": "1.3.0",
  "name": "code-from-spec",

  "specFormat": {
    "description": "spec-from-design이 생성하는 Spec 형식. code-from-spec은 이 형식을 소비한다.",
    "idPattern": "{PREFIX}-{DOMAIN}-{NUMBER} (예: PLM-POCANCEL-001, LMS-USER-001)",
    "types": ["usecase", "model", "service", "refactoring", "performance"],
    "typeClassification": "Spec 파일 내 '기본 정보' 섹션의 type 필드로 구분",
    "tcIdPattern": "TC-{DOMAIN}-{NUMBER}-{SEQ} (예: TC-POCANCEL-001-01)",
    "foundation": ["service-definition.md", "architecture-rules.md", "naming-guide.md", "infra-config.md"],
    "foundationLocation": "{doc_root}/ (specs 디렉토리 상위)",
    "policyLocation": "{doc_root}/policies/",
    "specLocation": "{doc_root}/specs/",
    "dependsOn": {
      "format": "기본 정보 테이블 내 dependsOn 필드 또는 별도 dependsOn 섹션",
      "schema": {
        "spec_id": "의존 대상 Spec ID (예: PLM-STYLE-001)",
        "shared_files": "수정 대상 파일 겹침 목록 (예: [\"Entity.java\"])",
        "reason": "의존 사유"
      },
      "empty": "dependsOn: [] (의존성 없음)"
    }
  },

  "workflows": {
    "full": {
      "description": "스케줄링 + Spec 기반 구현 + 빌드/테스트 + Spec 준수도 검증 + Spec 피드백",
      "steps": ["schedule", "implement", "build-verify", "verify-compliance", "feedback"],
      "agents": ["work-scheduler", "code-generator", "spec-verifier", "spec-feedback"]
    },
    "schedule": {
      "description": "Spec 의존성 분석 → Jira 티켓 생성 → Git worktree 구성 → 실행 계획 수립",
      "agents": ["work-scheduler"]
    },
    "implement": {
      "description": "Spec 기반 프로젝트 구현 (모호점 로그 포함)",
      "agents": ["code-generator"]
    },
    "verify": {
      "description": "구현된 코드의 Spec 준수도 검증 (Spec 갭 플래그 포함)",
      "agents": ["spec-verifier"]
    },
    "feedback": {
      "description": "모호점 로그 + 검증 리포트에서 Spec 수정 제안 생성 및 반영",
      "agents": ["spec-feedback"]
    }
  },

  "implementation": {
    "agentTeams": {
      "teammate1": {
        "role": "프로젝트 구조 + 인프라",
        "specSources": ["architecture-rules", "infra-config", "naming-guide"],
        "outputs": ["build config", "docker-compose", "application config"],
        "completionCriteria": "빌드 성공"
      },
      "teammate2": {
        "role": "도메인 모듈",
        "specSources": ["service-definition", "model-specs"],
        "outputs": ["domain/**"],
        "dependsOn": ["teammate1"]
      },
      "teammate3": {
        "role": "애플리케이션 + 인터페이스 + 인프라 모듈",
        "specSources": ["usecase-specs", "service-specs", "policies"],
        "outputs": ["application/**", "interfaces/**", "infrastructure/**"],
        "dependsOn": ["teammate2"]
      },
      "teammate4": {
        "role": "테스트 코드",
        "specSources": ["test-scenarios"],
        "outputs": ["src/test/**"],
        "dependsOn": ["teammate1", "teammate2", "teammate3"],
        "completionCriteria": "전체 테스트 통과"
      }
    },
    "buildVerification": {
      "maxRetries": 3,
      "criteria": ["빌드 성공", "전체 테스트 통과", "모든 TC-ID에 대응하는 테스트 존재"]
    }
  },

  "verification": {
    "areas": [
      {
        "id": "V1",
        "name": "기능 구현 완결성",
        "weight": 40,
        "description": "Spec의 기본 흐름과 수정 대상 파일이 모두 구현되었는지 확인",
        "measures": ["기본 흐름 구현 비율", "수정 대상 파일 구현 비율"],
        "specMapping": {
          "usecase": "usecase Spec → Application Service / Controller",
          "model": "model Spec → Entity / Repository",
          "service": "service Spec → Domain Service"
        }
      },
      {
        "id": "V2",
        "name": "비즈니스 규칙 준수",
        "weight": 30,
        "description": "policies/에 정의된 비즈니스 규칙이 코드에 정확히 반영되었는지 확인",
        "measures": ["비즈니스 규칙 구현 비율"],
        "specMapping": {
          "policy": "policies/ → Domain/Policy 클래스"
        }
      },
      {
        "id": "V3",
        "name": "아키텍처 준수",
        "weight": 15,
        "description": "architecture-rules.md의 아키텍처 규칙이 지켜졌는지 확인",
        "measures": ["아키텍처 규칙 준수 항목 수"],
        "specMapping": {
          "architecture": "architecture-rules.md → 패키지 구조, import 분석"
        }
      },
      {
        "id": "V4",
        "name": "테스트 커버리지",
        "weight": 15,
        "description": "Spec에 정의된 테스트 시나리오가 모두 구현되었는지 확인",
        "measures": ["TC-ID 커버리지", "테스트 통과율"],
        "specMapping": {
          "testCase": "TC-ID → @Tag 테스트"
        }
      }
    ],
    "totalScore": 100,
    "grades": {
      "A": { "min": 95, "label": "우수", "description": "Spec 충실 구현. 프로덕션 사용 가능" },
      "B": { "min": 85, "label": "양호", "description": "소규모 보완 후 사용 가능" },
      "C": { "min": 70, "label": "보통", "description": "주요 미준수 항목 존재" },
      "D": { "min": 0, "label": "부족", "description": "상당 부분 미구현 또는 불일치" }
    }
  },

  "feedback": {
    "sources": ["ambiguity-log", "compliance-report"],
    "target": "Spec 파일들",
    "requiresUserApproval": true,
    "categories": ["policies", "usecase-spec", "model-spec", "service-spec", "service-definition", "architecture-rules", "naming-guide"],
    "ambiguityLog": {
      "file": "{impl_dir}/ambiguity-log.md",
      "format": "AMB-{nn} 형식으로 기록",
      "generatedBy": "code-generator"
    }
  },

  "scheduling": {
    "description": "Spec 단위 작업 스케줄링 — Jira 티켓, Git worktree, 의존성 기반 실행 순서",
    "jira": {
      "ticketPerSpec": true,
      "project": "{jira_project}",
      "issueType": "Task",
      "fields": {
        "summary": "[Spec] {spec_id}: {spec_title}",
        "description": "Spec 기반 구현 작업\n\nSpec 파일: {spec_file}\n의존성: {dependencies}",
        "labels": ["spec-impl", "auto-generated"]
      },
      "transitions": {
        "created": "To Do",
        "implementing": "In Progress",
        "verifying": "In Review",
        "done": "Done"
      }
    },
    "worktree": {
      "enabled": true,
      "basePath": "{worktree_base}/",
      "branchPattern": "{jira_key}-{spec_id_kebab}",
      "cleanupOnMerge": true
    },
    "dependencies": {
      "source": "Spec 파일의 dependsOn 메타데이터 (spec-from-design이 생성)",
      "strategy": "topological-sort",
      "parallelExecution": true,
      "maxParallel": 3,
      "fallback": "Spec에 dependsOn이 없으면 모든 Spec을 독립으로 간주"
    }
  },

  "tracking": {
    "description": "Spec 파일에 구현 상태 기록 — Spec을 SSOT로 유지",
    "section": "## 구현 추적",
    "fields": {
      "status": "not-started | in-progress | completed | verified",
      "jiraTicket": "Jira 티켓 키 (예: PROJ-123)",
      "branch": "Git 브랜치명",
      "pr": "Pull Request URL",
      "commit": "최종 커밋 SHA",
      "completedAt": "완료 일시"
    },
    "location": "각 Spec 파일 최하단",
    "format": "YAML frontmatter 블록 (```yaml ... ```)"
  },

  "paths": {
    "specDir": "{spec_project}/{doc_root}/specs/",
    "policyDir": "{spec_project}/{doc_root}/policies/",
    "foundationDir": "{spec_project}/{doc_root}/",
    "implDir": "{target_dir}/",
    "reportDir": "reports/",
    "complianceReport": "reports/compliance-{date}.md",
    "feedbackReport": "reports/feedback-{date}.md",
    "ambiguityLog": "{impl_dir}/ambiguity-log.md",
    "workPlan": "reports/work-plan-{date}.md"
  }
}
